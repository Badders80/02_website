      "regex": "^/admin/horses/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPmicrochip": "nxtPmicrochip"
      },
      "namedRegex": "^/admin/horses/(?<nxtPmicrochip>[^/]+?)(?:/)?$"
    },
    {
      "page": "/marketplace/[id]",
