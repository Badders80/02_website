# App + Firebase (client)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_FIREBASE_CONFIG={"apiKey":"...","authDomain":"evolution-engine.firebaseapp.com","projectId":"evolution-engine",...}

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# For KYC claims in webhooks (get from GCP IAM service account json with Firebase Auth Admin)
FIREBASE_SERVICE_ACCOUNT_KEY='{"type":"service_account", "project_id":"evolution-engine", ... full json ...}'

# Optional: for holdings write from checkout webhook
GOOGLE_SHEETS_WEB_APP_URL=https://script.google.com/macros/s/.../exec

# Dev bypass (non-prod only)
NEXT_PUBLIC_BYPASS_AUTH_KYC=true
NEXT_PUBLIC_BYPASS_STRIPE=true
